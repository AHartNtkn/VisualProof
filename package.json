{
  "name": "visual-proof-assistant",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run --config vitest.config.ts",
    "test:physics": "vitest run --config vitest.physics.config.ts",
    "test:all": "vitest run --config vitest.all.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "emit:theories": "tsx scripts/emit-theories.ts",
    "demo": "vite demo",
    "app": "vite app",
    "preapp": "npm run emit:theories",
    "e2e": "playwright test",
    "pree2e": "npm run emit:theories"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20",
    "tsx": "^4.22.5",
    "typescript": "^5.5.0",
    "vite": "^5",
    "vitest": "^2.0.0"
  }
}
