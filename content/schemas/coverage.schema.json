{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cursebreaker://schemas/coverage",
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "ids": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
    "nonemptyIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/id" } }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["obligations", "puzzles"],
  "properties": {
    "obligations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "family", "distinction", "stoppingRule"],
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "kind": { "enum": ["onboarding", "isolated", "carried-interaction", "mixed"] },
          "family": { "$ref": "#/$defs/id" },
          "distinction": { "type": "string", "minLength": 1 },
          "stoppingRule": { "type": "string", "minLength": 1 }
        }
      }
    },
    "puzzles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["puzzle", "obligations", "visibleSituation", "defeats", "experientialNeighbors"],
        "properties": {
          "puzzle": { "$ref": "#/$defs/id" },
          "obligations": { "$ref": "#/$defs/nonemptyIds" },
          "visibleSituation": { "type": "string", "minLength": 1 },
          "defeats": { "type": "string", "minLength": 1 },
          "experientialNeighbors": { "$ref": "#/$defs/ids" }
        }
      }
    }
  }
}
