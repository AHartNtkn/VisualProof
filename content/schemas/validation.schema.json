{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cursebreaker://schemas/validation",
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "step": { "type": "object", "required": ["rule"], "properties": { "rule": { "type": "string", "minLength": 1 } } }
  },
  "type": "object", "additionalProperties": false,
  "required": ["puzzle", "solution", "availableArtifacts", "expectedRules", "recognizedStates"],
  "properties": {
    "puzzle": { "$ref": "#/$defs/id" },
    "solution": { "type": "array", "items": { "$ref": "#/$defs/step" } },
    "availableArtifacts": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/id" } },
    "expectedRules": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "recognizedStates": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false, "required": ["intervention", "demonstration"],
        "properties": { "intervention": { "$ref": "#/$defs/id" }, "demonstration": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/step" } } }
      }
    }
  }
}
