    targetBinders
        (layout.binderRegion
          (sourceEnumeration.binder relation.index)) =
      some ⟨arity,
        layout.patternMaterialRelationRenaming hadmissible region hregion
          sourceBinders targetBinders sourceCover targetCover sourceEnumeration
          relation⟩ := by
